{
    "extends": "./tsconfig.app.json",
    "compilerOptions": {
        "allowJs": true,
        "checkJs": false,
        "composite": false,
        "incremental": false,
        "noEmit": true
    },
    "include": [
        "src/domain/**/*.ts",
        "src/platform/**/*.ts",
        "src/repositories/**/*.ts",
        "src/services/authSnapshotService.ts",
        "src/services/authAutoLoginState.ts",
        "src/services/authSessionRecoveryService.ts",
        "src/services/configKeys.ts",
        "src/services/domainIngestionService.ts",
        "src/services/entityQueryCacheService.ts",
        "src/services/favoriteRemoteDetailsCacheService.ts",
        "src/services/friendRelationshipService.ts",
        "src/services/hostCapabilityService.ts",
        "src/services/legacyVrcxMigrationService.ts",
        "src/services/queryClient.ts",
        "src/services/recentActionService.ts",
        "src/services/realtime-presence/dispatcher.ts",
        "src/services/realtime-presence/notifications.ts",
        "src/services/sqliteErrorDialogService.ts",
        "src/services/startupServicesStatus.ts",
        "src/services/userIdentityService.ts",
        "src/services/vrcStatusService.ts",
        "src/services/zoomPreferenceService.ts",
        "src/shared/constants/**/*.ts",
        "src/shared/events/navLayoutEvents.ts",
        "src/shared/sqliteErrorEvents.ts",
        "src/shared/vrchatEndpoint.ts",
        "src/state/**/*.ts",
        "src/shared/utils/**/*.ts"
    ],
    "exclude": ["node_modules", "build", "dist"]
}
