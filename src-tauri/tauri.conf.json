{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "VRCX-0",
    "version": "2026.4.10",
    "identifier": "com.vrcx-0.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:9000",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "withGlobalTauri": false,
        "security": {
            "csp": {
                "img-src": ["https:", "http://localhost:*", "asset:", "vrcx-img:", "data:", "blob:"]
            }
        },
        "windows": [
            {
                "title": "VRCX-0",
                "width": 1024,
                "height": 768,
                "minWidth": 320,
                "minHeight": 240,
                "center": true,
                "decorations": true,
                "resizable": true
            }
        ],
        "trayIcon": {
            "id": "main",
            "iconPath": "icons/icon.png",
            "tooltip": "VRCX-0"
        }
    },
    "bundle": {
        "active": true,
        "resources": {
            "../LICENSE": "LICENSE",
            "../LICENSE-MIT": "LICENSE-MIT",
            "../dist/licenses/THIRD_PARTY_NOTICES.txt": "licenses/THIRD_PARTY_NOTICES.txt",
            "../dist/licenses/third-party-licenses.json": "licenses/third-party-licenses.json"
        },
        "targets": ["nsis"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "installerIcon": "icons/icon.ico",
                "displayLanguageSelector": false,
                "installMode": "currentUser"
            }
        }
    }
}
