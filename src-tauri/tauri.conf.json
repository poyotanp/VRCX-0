{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "VRCX-0",
  "version": "2026.4.8",
  "identifier": "com.vrcx-0.app",
  "build": {
    "frontendDist": "../build/html",
    "devUrl": "http://localhost:9000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run prod"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": {
        "img-src": ["'self'", "vrcx-img:", "http://vrcx-img.localhost", "data:", "blob:"]
      }
    },
    "windows": [
      {
        "title": "VRCX-0",
        "width": 1024,
        "height": 768,
        "minWidth": 320,
        "minHeight": 240,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "tooltip": "VRCX-0"
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "../LICENSE": "LICENSE",
      "../LICENSE-MIT": "LICENSE-MIT",
      "../build/html/licenses/THIRD_PARTY_NOTICES.txt": "licenses/THIRD_PARTY_NOTICES.txt",
      "../build/html/licenses/third-party-licenses.json": "licenses/third-party-licenses.json"
    },
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  }
}
