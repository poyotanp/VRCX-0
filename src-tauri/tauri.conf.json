{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "VRCX-0",
    "version": "2.7.0",
    "identifier": "com.vrcx-0.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:9000",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "withGlobalTauri": false,
        "security": {
            "csp": {
                "img-src": [
                    "https:",
                    "http://localhost:*",
                    "http://vrcx-0-img.localhost",
                    "http://vrcx-0-thumb.localhost",
                    "http://vrcx-0-bg-img.localhost",
                    "asset:",
                    "vrcx-0-img:",
                    "vrcx-0-thumb:",
                    "vrcx-0-bg-img:",
                    "data:",
                    "blob:"
                ],
                "worker-src": ["'self'", "blob:"]
            }
        },
        "windows": [
            {
                "label": "main",
                "create": false,
                "title": "VRCX-0",
                "width": 1024,
                "height": 768,
                "minWidth": 320,
                "minHeight": 240,
                "center": true,
                "decorations": false,
                "resizable": true
            }
        ],
        "trayIcon": {
            "id": "main",
            "iconPath": "icons/icon.png",
            "tooltip": "VRCX-0"
        }
    },
    "bundle": {
        "active": true,
        "resources": {
            "../LICENSE": "LICENSE",
            "../LICENSE-MIT": "LICENSE-MIT",
            "resources/licenses/THIRD_PARTY_NOTICES.txt": "licenses/THIRD_PARTY_NOTICES.txt"
        },
        "targets": ["nsis"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "digestAlgorithm": "sha256",
            "certificateThumbprint": "CF3C4BD75C0B82455ABEBFF09A2127FA92F6C140",
            "timestampUrl": "http://time.certum.pl",
            "nsis": {
                "installerIcon": "icons/icon.ico",
                "displayLanguageSelector": false,
                "installMode": "currentUser"
            }
        },
        "createUpdaterArtifacts": true
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwQTA3NTFDOTAxM0E3MjYKUldRbXB4T1FISFdnc0dXNWJhUEVNUVNNcm5ubytmR3lEdTBCUzJPUFY0dHpLcW1UdldwUFB4OWEK",
            "endpoints": [
                "https://github.com/Map1en/VRCX-0/releases/latest/download/latest_linux_and_macos.json",
                "https://github.com/Map1en/VRCX-0/releases/latest/download/latest_windows.json"
            ],
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
