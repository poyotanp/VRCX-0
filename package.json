    "scripts": {
        "dev": "vite",
        "tauri": "tauri",
        "tauri:dev": "tauri dev --features devtools",
        "tauri:build": "tauri build",
        "tauri:build:devtools": "tauri build --features devtools",
        "format": "oxfmt .",
        "format:check": "oxfmt --check .",
        "lint": "npm run lint:oxlint",
        "lint:oxlint": "oxlint .",
        "rust:check": "cargo check --workspace --all-targets",
        "rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
        "rust:fmt:check": "cargo fmt --all -- --check",
        "rust:machete": "cargo machete",
        "typecheck": "tsc -p tsconfig.typecheck.json --noEmit && tsc -p tsconfig.node.json --noEmit",
        "test": "vitest run --config vitest.config.ts",
        "test:watch": "vitest --config vitest.config.ts",
        "build:licenses": "node ./build-scripts/generate-third-party-licenses.ts",
        "build": "vite build && npm run build:licenses"
    },
