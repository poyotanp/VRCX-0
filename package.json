{
    "name": "VRCX-0",
    "private": true,
    "description": "An independent VRCX rewrite built with Tauri and Rust.",
    "keywords": [
        "VRChat"
    ],
    "license": "GPL-3.0-only",
    "author": "Map1en",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Map1en/VRCX-0"
    },
    "scripts": {
        "generate:native-locales": "node ./scripts/generate-native-locales.mjs",
        "generate:tauri-bindings": "cargo run --manifest-path src-tauri/Cargo.toml --features bindings-export --bin export-bindings && oxfmt src/platform/tauri/bindings.ts",
        "prepare": "husky",
        "predev": "npm run generate:native-locales",
        "dev": "vite",
        "tauri": "tauri",
        "pretauri:dev": "npm run generate:native-locales",
        "tauri:dev": "tauri dev --features devtools",
        "pretauri:dev:react-devtools": "npm run generate:native-locales",
        "tauri:dev:react-devtools": "set VITE_REACT_DEVTOOLS=1&& tauri dev --features devtools",
        "pretauri:dev:ws-log": "npm run generate:native-locales",
        "tauri:dev:ws-log": "set VRCX_0_WS_EVENT_LOG=1&& tauri dev --features devtools",
        "tauri:dev:overlay-preview": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/overlay-preview/run-dev-preview.ps1",
        "pretauri:build": "npm run generate:native-locales",
        "tauri:build": "tauri build",
        "pretauri:build:devtools": "npm run generate:native-locales",
        "tauri:build:devtools": "tauri build --features devtools",
        "pretauri:build:devkit": "npm run generate:native-locales",
        "tauri:build:devkit": "tauri build --features devkit",
        "format": "oxfmt . \"!**/*.{rs,toml,lock}\"",
        "format:check": "oxfmt --check . \"!**/*.{rs,toml,lock}\"",
        "lint": "oxlint . --ignore-pattern \"**/*.{rs,toml,lock}\"",
        "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
        "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
        "rust:fmt": "cargo fmt --all",
        "rust:fmt:check": "cargo fmt --all -- --check",
        "rust:test": "cargo test --workspace --exclude vrcx-0 --locked",
        "typecheck": "tsgo -p tsconfig.app.json --noEmit && tsgo -p tsconfig.node.json --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "build:licenses": "node ./scripts/generate-third-party-licenses.ts",
        "prebuild": "npm run generate:native-locales",
        "build": "vite build && npm run build:licenses"
    },
    "dependencies": {
        "@base-ui/react": "^1.6.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@fontsource-variable/geist": "^5.2.9",
        "@fontsource-variable/noto-sans-sc": "^5.2.10",
        "@sigma/edge-curve": "^3.1.0",
        "@sigma/node-border": "^3.0.0",
        "@tanstack/react-query": "^5.101.1",
        "@tanstack/react-table": "^8.21.3",
        "@tauri-apps/api": "^2.11.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.4.0",
        "echarts": "^6.1.0",
        "graphology": "^0.26.0",
        "graphology-communities-louvain": "^2.0.2",
        "graphology-layout-forceatlas2": "^0.10.1",
        "graphology-layout-noverlap": "^0.4.2",
        "i18next": "^26.3.2",
        "input-otp": "^1.4.2",
        "lucide-react": "^1.21.0",
        "radix-ui": "1.5.0",
        "react": "^19.2.7",
        "react-day-picker": "^10.0.1",
        "react-dom": "^19.2.7",
        "react-i18next": "^17.0.8",
        "react-markdown": "^10.1.0",
        "react-resizable-panels": "^4.11.2",
        "react-router-dom": "^7.18.0",
        "remark-gfm": "^4.0.1",
        "sigma": "^3.0.3",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.1",
        "@tauri-apps/cli": "^2.11.3",
        "@types/node": "^26.0.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@typescript/native-preview": "^7.0.0-dev.20260624.1",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/coverage-v8": "^4.1.9",
        "browserslist": "^4.28.4",
        "husky": "^9.1.7",
        "lightningcss": "^1.32.0",
        "lint-staged": "^17.0.8",
        "oxfmt": "^0.56.0",
        "oxlint": "^1.71.0",
        "shadcn": "^4.11.0",
        "tailwindcss": "^4.3.1",
        "tw-animate-css": "^1.4.0",
        "vite": "^8.1.0",
        "vitest": "^4.1.9"
    },
    "overrides": {
        "@radix-ui/react-dismissable-layer": "1.1.12"
    },
    "engines": {
        "node": ">=24.10.0",
        "npm": ">=11.5.0"
    }
}
